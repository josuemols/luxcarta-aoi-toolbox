# Copy to .streamlit/secrets.toml locally, or paste into the app's Secrets
# panel on Streamlit Community Cloud. Every entry is OPTIONAL — without any
# secrets the app runs open, with local downloads only.

# Password gate (same pattern as luxcarta-quote-app). Omit to leave the app
# open and rely on Streamlit's private-app viewer list instead.
app_password = "choose-a-password"

# Supabase Storage — enables the "Save to cloud & get link" button.
# Create a PUBLIC bucket (default name: aoi-toolbox) in Supabase Storage,
# then paste the project URL and a key with storage write access.
# AOI files are not proprietary, so a public bucket is acceptable.
supabase_url = "https://YOUR-PROJECT.supabase.co"
supabase_key = "YOUR-SERVICE-ROLE-OR-ANON-KEY"
supabase_bucket = "aoi-toolbox"
